{
	"name": "interactive-rails",
	"version": "0.2.0",
	"type": "module",
	"private": true,
	"//overrides": "Pin miniflare to avoid POST+non-2xx crash (fetch failed). Remove once https://github.com/cloudflare/workers-sdk/issues/13013 is fixed.",
	"overrides": {
		"miniflare": "4.20251217.0"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"deploy": "astro build && wrangler deploy",
		"db:migrate": "wrangler d1 execute interactive-rails-db --file=src/server/db/schema.sql --local",
		"db:migrate:prod": "wrangler d1 execute interactive-rails-db --file=src/server/db/schema.sql",
		"test": "bun test",
		"check-types": "astro check",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"validate:levels": "bun run scripts/validate-levels.ts"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.8",
		"@astrojs/cloudflare": "^13.1.8",
		"@astrojs/react": "^5.0.3",
		"@base-ui/react": "^1.3.0",
		"@fontsource-variable/geist-mono": "^5.2.7",
		"@fontsource-variable/inter": "^5.2.8",
		"@hono/zod-validator": "^0.7.6",
		"@monaco-editor/react": "^4.7.0",
		"@nanostores/react": "^1.0.0",
		"@radix-ui/react-slot": "^1.2.4",
		"@tanstack/react-query": "^5.62.0",
		"@xyflow/react": "^12.4.3",
		"astro": "^6.1.5",
		"better-auth": "^1.5.6",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"highlight.js": "^11.11.1",
		"hono": "^4.11.7",
		"immer": "^10.1.1",
		"lucide-react": "^1.8.0",
		"monaco-editor": "^0.55.1",
		"nanostores": "^1.1.1",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"react-resizable-panels": "^4.6.5",
		"shadcn": "^4.2.0",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.14",
		"@cloudflare/workers-types": "^4.20260129.0",
		"@tailwindcss/vite": "^4.1.18",
		"@types/bun": "latest",
		"@types/react": "^19.1.6",
		"@types/react-dom": "^19.1.5",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2"
	}
}
