		"test": "bun test"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260129.0",
		"@types/bun": "latest",
		"wrangler": "^4.61.0"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.6",
		"better-auth": "^1.5.6",
		"hono": "^4.11.7",
		"zod": "^4.3.6"
	}
}
