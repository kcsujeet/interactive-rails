{
	"name": "interactive-rails-worker",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "wrangler dev",
		"build": "wrangler deploy --dry-run",
		"deploy": "wrangler deploy",
