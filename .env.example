# Interactive Rails Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# Worker Environment (Cloudflare Workers)
# =============================================================================

# JWT Secret for signing authentication tokens
# IMPORTANT: Use a strong, random string of at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-min-32-characters

# Environment (development, staging, production)
ENVIRONMENT=development

# =============================================================================
# Database (Cloudflare D1)
# =============================================================================

# D1 Database ID (from Cloudflare dashboard)
# Not needed in wrangler.toml if using local D1
DATABASE_ID=your-d1-database-id

# =============================================================================
# Optional Configuration
# =============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=debug

# Rate limiting overrides (for development/testing)
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX_REQUESTS=10
# GENERAL_RATE_LIMIT_WINDOW_MS=60000
# GENERAL_RATE_LIMIT_MAX_REQUESTS=100
