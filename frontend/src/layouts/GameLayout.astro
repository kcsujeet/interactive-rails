---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/ui/Header.astro';

interface Props {
  title: string;
  fullscreen?: boolean;
}

const { title, fullscreen = false } = Astro.props;
---

<BaseLayout title={title}>
  <div class:list={["game-container", { "game-container--fullscreen": fullscreen }]}>
    {fullscreen ? (
      <div class="game-min-header">
        <a href="/acts" class="game-min-logo">
          <span class="game-min-icon">🔧</span>
          <span>RailsExpert</span>
        </a>
      </div>
    ) : (
      <Header />
    )}
    <main class:list={["game-main", { "game-main--fullscreen": fullscreen }]}>
      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  .game-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-game-bg);
  }

  .game-container--fullscreen {
    height: 100vh;
    overflow: hidden;
  }

  .game-main {
    flex: 1;
    padding: 24px;
  }

  .game-main--fullscreen {
    padding: 0;
    overflow: hidden;
  }

  .game-min-header {
    display: flex;
    align-items: center;
    padding: 0 20px;
    height: 48px;
    background: var(--color-game-surface);
    border-bottom: 1px solid var(--color-game-border);
  }

  .game-min-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    color: #f1f5f9;
    text-decoration: none;
    font-size: 0.875rem;
  }

  .game-min-icon {
    font-size: 1rem;
  }
</style>
