---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignupForm from '../components/auth/SignupForm';
---

<BaseLayout title="Create Account">
  <main class="auth-page">
    <div class="auth-container">
      <a href="/" class="back-link">← Back to Home</a>
      <div class="auth-card card">
        <div class="auth-header">
          <span class="logo-icon">🔧</span>
          <h1>RailsExpert</h1>
          <p class="tagline">Master Rails Performance</p>
        </div>
        <SignupForm client:load />
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    background: linear-gradient(135deg, var(--color-game-bg) 0%, var(--color-game-surface) 100%);
  }

  .auth-container {
    width: 100%;
    max-width: 400px;
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: #9ca3af;
    text-decoration: none;
    margin-bottom: 16px;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #3b82f6;
  }

  .auth-card {
    padding: 32px;
  }

  .auth-header {
    text-align: center;
    margin-bottom: 32px;
  }

  .logo-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 16px;
  }

  .auth-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #f3f4f6;
    margin: 0 0 8px 0;
  }

  .tagline {
    font-size: 0.875rem;
    color: #6b7280;
    margin: 0;
  }

  :global(.auth-form) {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  :global(.auth-form h2) {
    text-align: center;
    margin-bottom: 8px;
    font-size: 1.25rem;
    color: #f3f4f6;
  }

  :global(.form-group) {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  :global(.error-message) {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid #dc2626;
    border-radius: 0.5rem;
    padding: 12px;
    font-size: 0.875rem;
    color: #fca5a5;
  }

  :global(.auth-switch) {
    text-align: center;
    font-size: 0.875rem;
    color: #9ca3af;
    margin-top: 8px;
  }

  :global(.auth-switch a) {
    color: #3b82f6;
    text-decoration: none;
  }

  :global(.auth-switch a:hover) {
    text-decoration: underline;
  }
</style>
