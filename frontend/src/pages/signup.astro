---
import SignupForm from "@/components/auth/SignupForm";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Button } from "@/components/ui/Button";
---

<BaseLayout title="Create Account">
  <main class="relative min-h-screen flex items-center justify-center p-6 bg-background overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(oklch(0.75_0.16_55_/_0.04)_1px,transparent_1px)] bg-[size:24px_24px]" aria-hidden="true"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[radial-gradient(ellipse,oklch(0.75_0.16_55_/_0.06)_0%,transparent_70%)]" aria-hidden="true"></div>
    <div class="relative w-full max-w-[400px]">
      <Button variant="link" asChild className="mb-4 px-0">
        <a href="/">← Back to Home</a>
      </Button>
      <div class="text-center mb-8">
        <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center shadow-[0_0_30px_oklch(0.75_0.16_55_/_0.15)]">
          <img src="/favicon.svg" alt="RailsExpert Logo" class="w-10 h-10" />
        </div>
        <h1 class="text-2xl font-bold text-foreground mb-2">RailsExpert</h1>
        <p class="text-sm text-muted-foreground">Master Rails Performance</p>
      </div>
      <SignupForm client:load />
    </div>
  </main>
</BaseLayout>
