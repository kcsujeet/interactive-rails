---
import SignupForm from "@/components/auth/SignupForm";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Card } from "@/components/ui/Card";
import { Button } from "@/components/ui/Button";
---

<BaseLayout title="Create Account">
  <main class="min-h-screen flex items-center justify-center p-6 bg-background">
    <div class="w-full max-w-[400px]">
      <Button variant="link" asChild className="mb-4 px-0">
        <a href="/">← Back to Home</a>
      </Button>
      <Card className="p-8 shadow-xl">
        <div class="text-center mb-8">
          <img src="/favicon.svg" alt="RailsExpert Logo" class="w-16 h-16 mx-auto mb-4" />
          <h1 class="text-2xl font-bold text-foreground mb-2">RailsExpert</h1>
          <p class="text-sm text-muted-foreground">Master Rails Performance</p>
        </div>
        <SignupForm client:load />
      </Card>
    </div>
  </main>
</BaseLayout>
