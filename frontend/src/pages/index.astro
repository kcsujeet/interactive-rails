---
import Header from '@/components/ui/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Button } from '@/components/ui/Button';
import { Card } from '@/components/ui/Card';
import { Badge } from '@/components/ui/Badge';
import { Blocks, Sparkles, Search, Database, Cog, Rocket } from 'lucide-react';

const currentYear = new Date().getFullYear();
---

<BaseLayout title="Learn Rails Interactively">
  <main class="min-h-screen bg-background">
    <Header />

    <!-- Hero Section -->
    <section class="relative py-24 lg:py-32 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(oklch(0.75_0.16_55/0.07)_1px,transparent_1px)] bg-size-[32px_32px]" aria-hidden="true"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-[radial-gradient(ellipse,oklch(0.75_0.16_55/0.08)_0%,transparent_70%)]" aria-hidden="true"></div>
      <div class="relative max-w-[1200px] mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <Badge className="mb-6 animate-in fade-in duration-500">Interactive Learning</Badge>
            <h1 class="text-5xl lg:text-6xl font-bold mb-6 leading-[1.1] tracking-tight">
              <span class="block text-foreground">Learn Rails</span>
              <span class="block bg-linear-to-r from-primary via-amber-400 to-primary bg-clip-text text-transparent bg-size-[200%_auto] animate-shimmer">Interactively</span>
            </h1>
            <p class="text-lg text-muted-foreground mb-8 leading-relaxed animate-in fade-in slide-in-from-bottom-2 duration-500 delay-150">
              Understand Rails patterns through interactive pipeline simulations.
              Visualize request flows, detect N+1 queries, and learn optimization strategies.
            </p>
            <div class="flex flex-wrap gap-4" id="hero-cta">
              <Button size="xl">
                <a href="/dashboard" id="cta-primary">Start Learning</a>
              </Button>
              <Button variant="secondary" size="xl">
                <a href="#how-it-works">See How It Works</a>
              </Button>
            </div>
          </div>

          <div class="hidden lg:flex justify-center">
            <div class="relative group">
              <div class="absolute -inset-1 bg-linear-to-r from-primary/20 via-amber-400/20 to-primary/20 rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <Card className="relative w-full max-w-md overflow-hidden border-primary/20">
                <div class="flex items-center gap-2 px-4 py-3 bg-muted/50 border-b border-border">
                  <span class="w-3 h-3 rounded-full bg-destructive"></span>
                  <span class="w-3 h-3 rounded-full bg-warning"></span>
                  <span class="w-3 h-3 rounded-full bg-success"></span>
                  <span class="ml-auto text-xs text-muted-foreground uppercase tracking-wider">Pipeline Builder</span>
                </div>
                <div class="p-6 bg-[linear-gradient(rgba(56,189,248,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(56,189,248,0.05)_1px,transparent_1px)] bg-size-[20px_20px]">
                  <div class="flex flex-col items-center gap-2 mb-6">
                    <div class="px-4 py-2 rounded-md text-xs font-semibold bg-primary/20 border border-primary/40 text-foreground">Request</div>
                    <div class="w-0.5 h-5 bg-linear-to-b from-primary/40 to-primary/20 shadow-[0_0_6px_oklch(0.75_0.16_55/0.3)]"></div>
                    <div class="px-4 py-2 rounded-md text-xs font-semibold bg-violet-500/20 border border-violet-500/40 text-foreground">Router</div>
                    <div class="w-0.5 h-5 bg-linear-to-b from-violet-500/40 to-violet-500/20 shadow-[0_0_6px_oklch(0.60_0.15_300/0.3)]"></div>
                    <div class="px-4 py-2 rounded-md text-xs font-semibold bg-emerald-500/20 border border-emerald-500/40 text-foreground">Controller</div>
                    <div class="w-0.5 h-5 bg-linear-to-b from-emerald-500/40 to-emerald-500/20 shadow-[0_0_6px_oklch(0.65_0.17_160/0.3)]"></div>
                    <div class="px-4 py-2 rounded-md text-xs font-semibold bg-warning/20 border border-warning/40 text-foreground">Model</div>
                    <div class="w-0.5 h-5 bg-linear-to-b from-warning/40 to-warning/20 shadow-[0_0_6px_oklch(0.75_0.15_70/0.3)]"></div>
                    <div class="px-4 py-2 rounded-md text-xs font-semibold bg-destructive/20 border border-destructive/40 text-foreground relative animate-pulse shadow-[0_0_20px_oklch(0.60_0.20_25/0.4),0_0_40px_oklch(0.60_0.20_25/0.15)]">
                      Database
                      <span class="absolute -top-2 -right-2 px-1.5 py-0.5 text-[10px] bg-destructive rounded text-white">N+1!</span>
                    </div>
                  </div>
                  <div class="flex justify-around p-4 rounded-lg bg-muted/50 border border-border">
                    <div class="text-center">
                      <span class="block text-[10px] text-muted-foreground mb-1">Latency</span>
                      <span class="text-sm font-bold font-mono text-destructive">847ms</span>
                    </div>
                    <div class="text-center">
                      <span class="block text-[10px] text-muted-foreground mb-1">Queries</span>
                      <span class="text-sm font-bold font-mono text-destructive">127</span>
                    </div>
                    <div class="text-center">
                      <span class="block text-[10px] text-muted-foreground mb-1">Status</span>
                      <span class="text-sm font-bold font-mono text-warning">Slow</span>
                    </div>
                  </div>
                </div>
              </Card>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-muted/30" id="how-it-works">
      <div class="max-w-[1200px] mx-auto px-6">
        <h2 class="text-3xl font-bold text-center text-foreground mb-2">How It Works</h2>
        <p class="text-center text-muted-foreground mb-12">Learn Rails through hands-on exercises</p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <Card className="p-6 text-center hover-card animate-in fade-in slide-in-from-bottom-3 duration-500 delay-100 ">
            <div class="w-12 h-12 rounded-full bg-success/20 border border-success/50 flex items-center justify-center text-lg font-bold text-success mx-auto mb-4">1</div>
            <h3 class="font-semibold text-foreground mb-2">Build Pipelines</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">Drag and drop Rails components to construct request pipelines. Connect routes, controllers, models, and databases.</p>
          </Card>
          <Card className="p-6 text-center hover-card animate-in fade-in slide-in-from-bottom-3 duration-500 delay-200 ">
            <div class="w-12 h-12 rounded-full bg-info/20 border border-info/50 flex items-center justify-center text-lg font-bold text-info mx-auto mb-4">2</div>
            <h3 class="font-semibold text-foreground mb-2">Visualize Flows</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">See how requests flow through your pipeline. Understand the MVC pattern and identify bottlenecks visually.</p>
          </Card>
          <Card className="p-6 text-center hover-card animate-in fade-in slide-in-from-bottom-3 duration-500 delay-300 ">
            <div class="w-12 h-12 rounded-full bg-destructive/20 border border-destructive/50 flex items-center justify-center text-lg font-bold text-destructive mx-auto mb-4">3</div>
            <h3 class="font-semibold text-foreground mb-2">Learn Patterns</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">Understand N+1 queries, caching strategies, background jobs, and other Rails patterns through guided exercises.</p>
          </Card>
          <Card className="p-6 text-center hover-card animate-in fade-in slide-in-from-bottom-3 duration-500 delay-500 ">
            <div class="w-12 h-12 rounded-full bg-primary/20 border border-primary/50 flex items-center justify-center text-lg font-bold text-primary mx-auto mb-4">4</div>
            <h3 class="font-semibold text-foreground mb-2">Progress Through Acts</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">Work through 35 levels across 6 acts, from Rails fundamentals to system design and microservices.</p>
          </Card>
        </div>
      </div>
    </section>

    <!-- Concepts -->
    <section class="py-20">
      <div class="max-w-[1200px] mx-auto px-6">
        <h2 class="text-3xl font-bold text-center text-foreground mb-2">What You'll Learn</h2>
        <p class="text-center text-muted-foreground mb-12">From Rails basics to production-scale architecture</p>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <Card className="p-6 hover-card group ">
            <div class="w-14 h-14 rounded-xl bg-destructive/20 border border-destructive/50 flex items-center justify-center mb-4 transition-all duration-300 group-hover:bg-destructive/25">
              <Blocks className="w-7 h-7 text-destructive" />
            </div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Rails Fundamentals</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">Master MVC architecture, ActiveRecord associations, validations, and the request lifecycle.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-destructive">has_many</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-destructive">belongs_to</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-destructive">validates</span>
            </div>
          </Card>

          <Card className="p-6 hover-card group ">
            <div class="w-14 h-14 rounded-xl bg-info/20 border border-info/50 flex items-center justify-center mb-4 transition-all duration-300 group-hover:bg-info/25">
              <Sparkles className="w-7 h-7 text-info" />
            </div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Clean Code Patterns</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">Refactor fat controllers with service objects, validation contracts, and proper separation of concerns.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-info">Services</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-info">Dry::Validation</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-info">SRP</span>
            </div>
          </Card>

          <Card className="p-6 hover-card group ">
            <div class="w-14 h-14 rounded-xl bg-warning/20 border border-warning/50 flex items-center justify-center mb-4 transition-all duration-300 group-hover:bg-warning/25">
              <Search className="w-7 h-7 text-warning" />
            </div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Query Optimization</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">Detect and fix N+1 queries, add proper indexes, and use eager loading effectively.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-warning">includes()</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-warning">add_index</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-warning">explain</span>
            </div>
          </Card>

          <Card className="p-6 hover-card group ">
            <div class="w-14 h-14 rounded-xl bg-success/20 border border-success/50 flex items-center justify-center mb-4 transition-all duration-300 group-hover:bg-success/25">
              <Database className="w-7 h-7 text-success" />
            </div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Caching & Performance</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">Implement caching strategies from fragment caching to Russian doll patterns with Redis.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-success">Rails.cache</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-success">Redis</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-success">cache_key</span>
            </div>
          </Card>

          <Card className="p-6 hover-card group ">
            <div class="w-14 h-14 rounded-xl bg-primary/20 border border-primary/50 flex items-center justify-center mb-4 transition-all duration-300 group-hover:bg-primary/25">
              <Cog className="w-7 h-7 text-primary" />
            </div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Background Processing</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">Handle async operations with Sidekiq, manage job queues, and ensure idempotency.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-primary">Sidekiq</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-primary">perform_later</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-primary">ActiveJob</span>
            </div>
          </Card>

          <Card className="p-6 hover-card group ">
            <div class="w-14 h-14 rounded-xl bg-info/20 border border-info/50 flex items-center justify-center mb-4 transition-all duration-300 group-hover:bg-info/25">
              <Rocket className="w-7 h-7 text-info" />
            </div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Production & Scale</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">Build resilient systems with circuit breakers, read replicas, sharding, and observability.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-info">Circuit Breaker</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-info">Replicas</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-info">Sharding</span>
            </div>
          </Card>
        </div>
      </div>
    </section>

    <!-- Levels Preview -->
    <section class="py-20 bg-muted/30">
      <div class="max-w-[1200px] mx-auto px-6">
        <h2 class="text-3xl font-bold text-center text-foreground mb-2">Learning Path</h2>
        <p class="text-center text-muted-foreground mb-12">35 levels across 6 acts - from Rails basics to system design</p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <Card className="p-6 hover-card ">
            <div class="flex justify-between items-center mb-3">
              <Badge color="success" variant="soft">Act I</Badge>
              <span class="text-xs text-muted-foreground">8 levels</span>
            </div>
            <h3 class="font-semibold text-foreground mb-2">Rails Fundamentals</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-3">MVC architecture, associations, validations, and the request lifecycle.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-success">has_many</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-success">belongs_to</span>
            </div>
          </Card>

          <Card className="p-6 hover-card ">
            <div class="flex justify-between items-center mb-3">
              <Badge color="info" variant="soft">Act II-III</Badge>
              <span class="text-xs text-muted-foreground">13 levels</span>
            </div>
            <h3 class="font-semibold text-foreground mb-2">Clean Code & Performance</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-3">Refactoring patterns, service objects, N+1 queries, and caching strategies.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-info">includes()</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-info">Rails.cache</span>
            </div>
          </Card>

          <Card className="p-6 hover-card ">
            <div class="flex justify-between items-center mb-3">
              <Badge color="warning" variant="soft">Act IV-V</Badge>
              <span class="text-xs text-muted-foreground">10 levels</span>
            </div>
            <h3 class="font-semibold text-foreground mb-2">Production & Infrastructure</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-3">Security, background jobs, Redis, error handling, and resilience patterns.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-warning">Sidekiq</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-warning">Circuit Breaker</span>
            </div>
          </Card>

          <Card className="p-6 hover-card  ">
            <div class="flex justify-between items-center mb-3">
              <Badge color="destructive" variant="soft">Act VI</Badge>
              <span class="text-xs text-muted-foreground">4 levels</span>
            </div>
            <h3 class="font-semibold text-foreground mb-2">System Design</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-3">Database scaling, read replicas, sharding, and distributed architecture.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-destructive">Read Replicas</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-destructive">Sharding</span>
            </div>
          </Card>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="relative py-24 overflow-hidden">
      <div class="absolute inset-0 bg-linear-to-r from-primary/5 via-amber-500/10 to-primary/5"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,oklch(0.75_0.16_55/0.1)_0%,transparent_60%)]"></div>
      <div class="relative max-w-[1200px] mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold text-foreground mb-3">Ready to Learn?</h2>
        <p class="text-muted-foreground mb-8">Start learning Rails through interactive exercises.</p>
        <Button size="xl">
          <a href="/dashboard" id="cta-bottom">Start Learning</a>
        </Button>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-8 border-t border-border/50">
      <div class="max-w-[1200px] mx-auto px-6 flex items-center justify-between">
        <p class="text-sm text-muted-foreground">&copy; {currentYear} RailsExpert</p>
        <div class="flex items-center gap-1">
          <span class="text-xs text-muted-foreground/50">Built with</span>
          <span class="text-xs text-primary">Rails + React</span>
        </div>
      </div>
    </footer>
  </main>
</BaseLayout>

