---
import Header from "@/components/ui/Header.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Button } from "@/components/ui/Button";
import { Card } from "@/components/ui/Card";
import { Badge } from "@/components/ui/Badge";
---

<BaseLayout title="Master Rails Performance">
  <main class="min-h-screen bg-background">
    <Header />

    <!-- Hero Section -->
    <section class="py-24 lg:py-32">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <Badge className="mb-6">New Learning Experience</Badge>
            <h1 class="text-4xl lg:text-5xl font-bold mb-6 leading-tight">
              <span class="block text-foreground">Master Rails</span>
              <span class="block bg-gradient-to-r from-primary to-cyan-400 bg-clip-text text-transparent">Performance</span>
            </h1>
            <p class="text-lg text-muted-foreground mb-8 leading-relaxed">
              Build, debug, and optimize Rails request pipelines in an interactive simulation.
              Watch N+1 queries spawn enemies and cache hits create shields in real-time.
            </p>
            <div class="flex flex-wrap gap-4" id="hero-cta">
              <Button asChild size="xl">
                <a href="/dashboard" id="cta-primary">Start Learning</a>
              </Button>
              <Button asChild variant="outline" size="xl">
                <a href="#how-it-works">See How It Works</a>
              </Button>
            </div>
          </div>

          <div class="hidden lg:flex justify-center">
            <Card className="w-full max-w-md overflow-hidden">
              <div class="flex items-center gap-2 px-4 py-3 bg-muted/50 border-b border-border">
                <span class="w-3 h-3 rounded-full bg-destructive"></span>
                <span class="w-3 h-3 rounded-full bg-warning"></span>
                <span class="w-3 h-3 rounded-full bg-success"></span>
                <span class="ml-auto text-xs text-muted-foreground uppercase tracking-wider">Pipeline Builder</span>
              </div>
              <div class="p-6 bg-[linear-gradient(rgba(56,189,248,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(56,189,248,0.05)_1px,transparent_1px)] bg-[size:20px_20px]">
                <div class="flex flex-col items-center gap-2 mb-6">
                  <div class="px-4 py-2 rounded-md text-xs font-semibold bg-primary/20 border border-primary/40 text-foreground">Request</div>
                  <div class="w-0.5 h-4 bg-border"></div>
                  <div class="px-4 py-2 rounded-md text-xs font-semibold bg-blue-500/20 border border-blue-500/40 text-foreground">Router</div>
                  <div class="w-0.5 h-4 bg-border"></div>
                  <div class="px-4 py-2 rounded-md text-xs font-semibold bg-cyan-500/20 border border-cyan-500/40 text-foreground">Controller</div>
                  <div class="w-0.5 h-4 bg-border"></div>
                  <div class="px-4 py-2 rounded-md text-xs font-semibold bg-warning/20 border border-warning/40 text-foreground">Model</div>
                  <div class="w-0.5 h-4 bg-border"></div>
                  <div class="px-4 py-2 rounded-md text-xs font-semibold bg-destructive/20 border border-destructive/40 text-foreground relative animate-pulse shadow-[0_0_20px_rgba(244,63,94,0.3)]">
                    Database
                    <span class="absolute -top-2 -right-2 px-1.5 py-0.5 text-[10px] bg-destructive rounded text-white">N+1!</span>
                  </div>
                </div>
                <div class="flex justify-around p-4 rounded-lg bg-muted/50 border border-border">
                  <div class="text-center">
                    <span class="block text-[10px] text-muted-foreground mb-1">Latency</span>
                    <span class="text-sm font-bold font-mono text-destructive">847ms</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-[10px] text-muted-foreground mb-1">Queries</span>
                    <span class="text-sm font-bold font-mono text-destructive">127</span>
                  </div>
                  <div class="text-center">
                    <span class="block text-[10px] text-muted-foreground mb-1">Stability</span>
                    <span class="text-sm font-bold font-mono text-warning">34%</span>
                  </div>
                </div>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-muted/30" id="how-it-works">
      <div class="max-w-[1200px] mx-auto px-6">
        <h2 class="text-3xl font-bold text-center text-foreground mb-2">How It Works</h2>
        <p class="text-center text-muted-foreground mb-12">Learn Rails performance through hands-on simulation</p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <Card className="p-6 text-center">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary to-cyan-400 flex items-center justify-center text-lg font-bold text-white mx-auto mb-4">1</div>
            <h3 class="font-semibold text-foreground mb-2">Build Pipelines</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">Drag and drop Rails components to construct request pipelines. Connect routes, controllers, models, and databases.</p>
          </Card>
          <Card className="p-6 text-center">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary to-cyan-400 flex items-center justify-center text-lg font-bold text-white mx-auto mb-4">2</div>
            <h3 class="font-semibold text-foreground mb-2">Watch the Simulation</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">See requests flow through your pipeline in real-time. Misconfigurations spawn enemies that attack your system stability.</p>
          </Card>
          <Card className="p-6 text-center">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary to-cyan-400 flex items-center justify-center text-lg font-bold text-white mx-auto mb-4">3</div>
            <h3 class="font-semibold text-foreground mb-2">Debug & Optimize</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">Use the inspector to find N+1 queries, add indexes, implement caching, and deploy defenses to stabilize your system.</p>
          </Card>
          <Card className="p-6 text-center">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary to-cyan-400 flex items-center justify-center text-lg font-bold text-white mx-auto mb-4">4</div>
            <h3 class="font-semibold text-foreground mb-2">Complete Acts</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">Progress through 35 levels across 6 acts, each teaching core Rails performance concepts. Earn stars and unlock advanced techniques.</p>
          </Card>
        </div>
      </div>
    </section>

    <!-- Concepts -->
    <section class="py-20">
      <div class="max-w-[1200px] mx-auto px-6">
        <h2 class="text-3xl font-bold text-center text-foreground mb-2">Rails Concepts → Game Mechanics</h2>
        <p class="text-center text-muted-foreground mb-12">Abstract concepts become tangible through visual feedback</p>

        <div class="grid md:grid-cols-2 gap-6">
          <Card className="p-6">
            <div class="w-14 h-14 rounded-xl bg-primary/10 border border-primary/30 flex items-center justify-center text-3xl mb-4">👾</div>
            <h3 class="text-lg font-semibold text-foreground mb-2">N+1 Queries</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">Each N+1 query spawns a Query Swarm enemy that attacks your system. Add eager loading to defeat them.</p>
            <div class="flex items-center gap-2 p-3 rounded-md bg-muted/50 text-xs font-mono">
              <span class="text-warning">includes(:posts)</span>
              <span class="text-muted-foreground">→</span>
              <span class="text-success">Eager Loader Defense</span>
            </div>
          </Card>

          <Card className="p-6">
            <div class="w-14 h-14 rounded-xl bg-primary/10 border border-primary/30 flex items-center justify-center text-3xl mb-4">🛡️</div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Caching</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">Cache hits generate protective shields around your nodes. Russian doll caching creates nested defenses.</p>
            <div class="flex items-center gap-2 p-3 rounded-md bg-muted/50 text-xs font-mono">
              <span class="text-warning">Rails.cache.fetch</span>
              <span class="text-muted-foreground">→</span>
              <span class="text-success">Cache Shield</span>
            </div>
          </Card>

          <Card className="p-6">
            <div class="w-14 h-14 rounded-xl bg-primary/10 border border-primary/30 flex items-center justify-center text-3xl mb-4">🎯</div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Database Indexes</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">Indexes become speed turrets that accelerate queries passing through. Missing indexes slow everything down.</p>
            <div class="flex items-center gap-2 p-3 rounded-md bg-muted/50 text-xs font-mono">
              <span class="text-warning">add_index :users, :email</span>
              <span class="text-muted-foreground">→</span>
              <span class="text-success">Index Turret</span>
            </div>
          </Card>

          <Card className="p-6">
            <div class="w-14 h-14 rounded-xl bg-primary/10 border border-primary/30 flex items-center justify-center text-3xl mb-4">⚙️</div>
            <h3 class="text-lg font-semibold text-foreground mb-2">Background Jobs</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-4">Sidekiq workers become automated drones that handle heavy processing without blocking requests.</p>
            <div class="flex items-center gap-2 p-3 rounded-md bg-muted/50 text-xs font-mono">
              <span class="text-warning">perform_later</span>
              <span class="text-muted-foreground">→</span>
              <span class="text-success">Worker Drone</span>
            </div>
          </Card>
        </div>
      </div>
    </section>

    <!-- Levels Preview -->
    <section class="py-20 bg-muted/30">
      <div class="max-w-[1200px] mx-auto px-6">
        <h2 class="text-3xl font-bold text-center text-foreground mb-2">Progressive Learning Path</h2>
        <p class="text-center text-muted-foreground mb-12">35 levels across 6 acts - from fundamentals to production-grade optimization</p>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <Card className="p-6">
            <div class="flex justify-between items-center mb-3">
              <Badge variant="success" className="text-[10px]">Act I</Badge>
              <span class="text-sm text-warning">★☆☆☆☆</span>
            </div>
            <h3 class="font-semibold text-foreground mb-2">Birth of the App</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-3">Learn MVC basics, associations, validations, and callbacks through the foundational act.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-primary">has_many</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-primary">belongs_to</span>
            </div>
          </Card>

          <Card className="p-6">
            <div class="flex justify-between items-center mb-3">
              <Badge className="text-[10px] bg-blue-500/15 text-blue-400 border-transparent">Act II-III</Badge>
              <span class="text-sm text-warning">★★★☆☆</span>
            </div>
            <h3 class="font-semibold text-foreground mb-2">Growth & Scale</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-3">Fix N+1 queries, add indexes, implement caching, and background jobs across the middle acts.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-primary">includes()</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-primary">Rails.cache</span>
            </div>
          </Card>

          <Card className="p-6">
            <div class="flex justify-between items-center mb-3">
              <Badge className="text-[10px] bg-purple-500/15 text-purple-400 border-transparent">Act IV-V</Badge>
              <span class="text-sm text-warning">★★★★☆</span>
            </div>
            <h3 class="font-semibold text-foreground mb-2">Production & Infrastructure</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-3">Handle security, concurrency, Redis, Sidekiq, and message queues across late acts.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-primary">Circuit Breaker</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-primary">Pub/Sub</span>
            </div>
          </Card>

          <Card className="p-6">
            <div class="flex justify-between items-center mb-3">
              <Badge variant="destructive" className="text-[10px]">Act VI</Badge>
              <span class="text-sm text-warning">★★★★★</span>
            </div>
            <h3 class="font-semibold text-foreground mb-2">Platform & Expert</h3>
            <p class="text-sm text-muted-foreground leading-relaxed mb-3">Master APIs, observability, sharding, and incident response in the capstone act.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-primary">Read Replicas</span>
              <span class="text-[10px] font-mono px-2 py-1 rounded bg-muted text-primary">Feature Flags</span>
            </div>
          </Card>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-gradient-to-r from-primary/10 to-cyan-500/10 border-y border-border">
      <div class="max-w-[1200px] mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold text-foreground mb-3">Ready to Optimize?</h2>
        <p class="text-muted-foreground mb-8">Start building pipelines and mastering Rails performance today.</p>
        <Button asChild size="xl">
          <a href="/dashboard" id="cta-bottom">Start Learning</a>
        </Button>
      </div>
    </section>

    <!-- Footer -->
    <footer class="py-6 text-center text-sm text-muted-foreground">
      <div class="max-w-[1200px] mx-auto px-6">
        <p>© 2024 RailsExpert. Learn Rails performance through simulation.</p>
      </div>
    </footer>
  </main>
</BaseLayout>

<script>
  const USER_KEY = 'railsexpert_user';
  const user = localStorage.getItem(USER_KEY);

  if (user) {
    const ctaPrimary = document.getElementById('cta-primary');
    if (ctaPrimary) {
      ctaPrimary.href = '/dashboard';
      ctaPrimary.textContent = 'Open Dashboard';
    }

    const ctaBottom = document.getElementById('cta-bottom');
    if (ctaBottom) {
      ctaBottom.href = '/dashboard';
      ctaBottom.textContent = 'Go to Dashboard';
    }
  }
</script>
