---
import GameLayout from '../layouts/GameLayout.astro';
---

<GameLayout title="Dashboard">
  <div class="dashboard">
    <header class="dashboard-header">
      <h1>Your Progress</h1>
      <a href="/acts" class="btn btn-primary">Start Learning</a>
    </header>

    <div class="dashboard-grid" id="dashboard-content">
      <div class="loading card">
        <span class="loading-text">Loading stats...</span>
      </div>
    </div>
  </div>
</GameLayout>

<script>
  import { escapeHtml } from '../lib/utils';

  async function loadDashboard() {
    const container = document.getElementById('dashboard-content');
    if (!container) return;

    try {
      // Use the new pipeline progress API
      const response = await fetch('/api/pipeline/progress', {
        credentials: 'include',
      });

      if (!response.ok) {
        if (response.status === 401) {
          window.location.href = '/login';
          return;
        }
        const errorData = await response.json().catch(() => ({}));
        throw new Error(errorData?.error?.message || 'Failed to load progress');
      }

      const result = await response.json();
      const progress = result.data;

      const xpForNextLevel = progress.xpToNextLevel || Math.floor(100 * Math.pow(1.5, progress.level));
      const xpPercent = Math.round((progress.xp / xpForNextLevel) * 100);

      // Format play time
      const totalMinutes = Math.floor((progress.stats?.totalPlayTime || 0) / 60);
      const playTimeText = totalMinutes < 60
        ? `${totalMinutes} min`
        : `${Math.floor(totalMinutes / 60)}h ${totalMinutes % 60}m`;

      container.innerHTML = `
        <div class="stats-card card">
          <h2>Player Stats</h2>
          <div class="stat-row">
            <span class="stat-label">Level</span>
            <span class="stat-value level-badge">${progress.level}</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Experience</span>
            <div class="progress-bar">
              <div class="progress-fill" style="width: ${xpPercent}%"></div>
              <span class="progress-text">${progress.xp}/${xpForNextLevel} XP</span>
            </div>
          </div>
          <div class="stat-row">
            <span class="stat-label">Current Title</span>
            <span class="stat-value">${progress.currentTitle || 'Novice'}</span>
          </div>
        </div>

        <div class="stats-card card">
          <h2>Performance</h2>
          <div class="stat-row">
            <span class="stat-label">Levels Completed</span>
            <span class="stat-value">${progress.stats?.levelsCompleted || progress.stats?.dungeonsCompleted || 0}</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Total Stars</span>
            <span class="stat-value stars">${progress.stats?.totalStarsEarned || 0} ★</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Total Play Time</span>
            <span class="stat-value">${playTimeText}</span>
          </div>
        </div>

        <div class="stats-card card wide">
          <h2>Unlocked Abilities</h2>
          <div class="unlocks-grid">
            <div class="unlock-category">
              <h3>Nodes</h3>
              <div class="unlock-tags">
                ${(progress.unlockedNodes || []).map((n: string) => `<span class="unlock-tag node">${n}</span>`).join('')}
              </div>
            </div>
            <div class="unlock-category">
              <h3>Defenses</h3>
              <div class="unlock-tags">
                ${(progress.unlockedDefenses || []).map((d: string) => `<span class="unlock-tag defense">${d.replace('_', ' ')}</span>`).join('')}
              </div>
            </div>
          </div>
        </div>

        <div class="quick-actions card wide">
          <h2>Quick Actions</h2>
          <div class="actions-grid">
            <a href="/acts" class="action-card">
              <span class="action-icon">📚</span>
              <span class="action-title">Acts</span>
              <span class="action-desc">Learn Rails through 80 levels</span>
            </a>
            <a href="/sandbox" class="action-card">
              <span class="action-icon">🔧</span>
              <span class="action-title">Sandbox</span>
              <span class="action-desc">Practice building pipelines</span>
            </a>
          </div>
        </div>
      `;
    } catch (err) {
      console.error('Dashboard load error:', err);
      const errorMessage = err instanceof Error ? err.message : 'Unknown error';
      const isAuthError = errorMessage.includes('Unauthorized') || errorMessage.includes('Invalid token');

      container.innerHTML = `
        <div class="error card wide">
          <p>${isAuthError ? 'Please log in to view your dashboard.' : `Error: ${escapeHtml(errorMessage)}`}</p>
          ${isAuthError
            ? '<a href="/login" class="btn btn-primary">Login</a>'
            : '<button class="btn btn-secondary" onclick="window.location.reload()">Retry</button>'
          }
        </div>
      `;
    }
  }

  loadDashboard();
</script>

<style>
  .dashboard {
    max-width: 1000px;
    margin: 0 auto;
    padding: 24px;
  }

  .dashboard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
  }

  .dashboard-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #f3f4f6;
    margin: 0;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  :global(.stats-card) {
    padding: 24px;
  }

  :global(.stats-card.wide),
  :global(.card.wide) {
    grid-column: 1 / -1;
  }

  :global(.stats-card h2),
  :global(.quick-actions h2) {
    font-size: 0.875rem;
    font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 20px 0;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-game-border);
  }

  :global(.stat-row) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid var(--color-game-border);
  }

  :global(.stat-row:last-child) {
    border-bottom: none;
  }

  :global(.stat-label) {
    font-size: 0.875rem;
    color: #9ca3af;
  }

  :global(.stat-value) {
    font-size: 1rem;
    font-weight: 600;
    color: #f3f4f6;
  }

  :global(.stat-value.level-badge) {
    background: linear-gradient(135deg, #3b82f6, #8b5cf6);
    color: white;
    padding: 4px 16px;
    border-radius: 9999px;
    font-size: 0.875rem;
  }

  :global(.stat-value.streak) {
    color: #f59e0b;
  }

  :global(.stat-value.stars) {
    color: #fbbf24;
  }

  :global(.progress-bar) {
    flex: 1;
    height: 1.5rem;
    background-color: var(--color-game-border);
    border-radius: 9999px;
    overflow: hidden;
    position: relative;
    margin-left: 1rem;
  }

  :global(.progress-fill) {
    height: 100%;
    background: linear-gradient(to right, #22c55e, #4ade80);
    transition: width 300ms ease-out;
    border-radius: 9999px;
  }

  :global(.progress-text) {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 500;
    color: white;
  }

  :global(.unlocks-grid) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  :global(.unlock-category h3) {
    font-size: 0.75rem;
    font-weight: 600;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 12px;
  }

  :global(.unlock-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  :global(.unlock-tag) {
    padding: 6px 12px;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: capitalize;
  }

  :global(.unlock-tag.node) {
    background: rgba(59, 130, 246, 0.15);
    color: #60a5fa;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  :global(.unlock-tag.defense) {
    background: rgba(34, 197, 94, 0.15);
    color: #4ade80;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  :global(.quick-actions) {
    padding: 24px;
  }

  :global(.actions-grid) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  :global(.action-card) {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px;
    background: var(--color-game-bg);
    border: 1px solid var(--color-game-border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: all 200ms;
  }

  :global(.action-card:hover) {
    border-color: #3b82f6;
    transform: translateY(-2px);
  }

  :global(.action-icon) {
    font-size: 2.5rem;
    margin-bottom: 12px;
  }

  :global(.action-title) {
    font-size: 1rem;
    font-weight: 600;
    color: #f3f4f6;
    margin-bottom: 4px;
  }

  :global(.action-desc) {
    font-size: 0.75rem;
    color: #6b7280;
  }

  .loading {
    grid-column: 1 / -1;
    text-align: center;
    padding: 48px;
  }

  .loading-text {
    font-size: 0.875rem;
    color: #6b7280;
    animation: pulse 1.5s infinite;
  }

  :global(.error) {
    text-align: center;
    padding: 48px;
  }

  :global(.error p) {
    margin-bottom: 16px;
    color: #9ca3af;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  @media (max-width: 768px) {
    .dashboard-grid {
      grid-template-columns: 1fr;
    }

    :global(.achievements-grid) {
      grid-template-columns: repeat(2, 1fr);
    }

    :global(.actions-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>
