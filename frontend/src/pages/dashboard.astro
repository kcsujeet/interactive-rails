---
import GameLayout from '@/layouts/GameLayout.astro';
import { Button } from '@/components/ui/Button';
import { Card } from '@/components/ui/Card';
---

<GameLayout title="Dashboard">
  <div class="max-w-[1000px] mx-auto p-6">
    <Card className="flex justify-between items-center p-5 mb-8">
      <h1 class="text-2xl font-bold text-foreground">Your Progress</h1>
      <Button asChild>
        <a href="/acts">Start Learning</a>
      </Button>
    </Card>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="dashboard-content">
      <div class="bg-card text-card-foreground rounded-xl border py-6 shadow-md p-6">
        <div class="shimmer h-4 w-24 rounded mb-6"></div>
        <div class="space-y-4">
          <div class="shimmer h-3 w-full rounded"></div>
          <div class="shimmer h-3 w-3/4 rounded"></div>
          <div class="shimmer h-3 w-1/2 rounded"></div>
        </div>
      </div>
      <div class="bg-card text-card-foreground rounded-xl border py-6 shadow-md p-6">
        <div class="shimmer h-4 w-24 rounded mb-6"></div>
        <div class="space-y-4">
          <div class="shimmer h-3 w-full rounded"></div>
          <div class="shimmer h-3 w-3/4 rounded"></div>
          <div class="shimmer h-3 w-1/2 rounded"></div>
        </div>
      </div>
    </div>
  </div>
</GameLayout>

<script>
  import { escapeHtml } from "../lib/utils";

  // Tailwind classes for dynamic innerHTML (matching UI components)
  const cardClass = "bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-md";
  const primaryBtnClass = "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-lg text-sm font-medium transition-colors bg-primary text-primary-foreground shadow hover:bg-primary/90 h-9 px-4 py-2";
  const secondaryBtnClass = "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-lg text-sm font-medium transition-colors border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground h-9 px-4 py-2";

  async function loadDashboard() {
    const container = document.getElementById('dashboard-content');
    if (!container) return;

    try {
      const response = await fetch('/api/pipeline/progress', {
        credentials: 'include',
      });

      if (!response.ok) {
        if (response.status === 401) {
          window.location.href = '/login';
          return;
        }
        const errorData = await response.json().catch(() => ({}));
        throw new Error(errorData?.error?.message || 'Failed to load progress');
      }

      const result = await response.json();
      const progress = result.data;

      const xpForNextLevel = progress.xpToNextLevel || Math.floor(100 * Math.pow(1.5, progress.level));
      const xpPercent = Math.round((progress.xp / xpForNextLevel) * 100);

      const totalMinutes = Math.floor((progress.stats?.totalPlayTime || 0) / 60);
      const playTimeText = totalMinutes < 60
        ? `${totalMinutes} min`
        : `${Math.floor(totalMinutes / 60)}h ${totalMinutes % 60}m`;

      container.innerHTML = `
        <div class="${cardClass} p-6">
          <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-5 pb-3 border-b border-border">Player Stats</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center py-3 border-b border-border/50">
              <span class="text-sm text-muted-foreground flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary inline-block"></span>Level</span>
              <span class="px-4 py-1 rounded-full text-sm font-semibold bg-linear-to-r from-primary to-amber-400 text-primary-foreground">${progress.level}</span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-border/50 gap-4">
              <span class="text-sm text-muted-foreground flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block"></span>Experience</span>
              <div class="flex-1 h-6 bg-muted rounded-full overflow-hidden relative border border-border">
                <div class="h-full bg-linear-to-r from-primary to-amber-400 rounded-full transition-all duration-700 ease-out relative overflow-hidden" style="width: ${xpPercent}%"><div class="absolute inset-0 shimmer opacity-30"></div></div>
                <span class="absolute inset-0 flex items-center justify-center text-xs font-medium text-foreground">${progress.xp}/${xpForNextLevel} XP</span>
              </div>
            </div>
            <div class="flex justify-between items-center py-3">
              <span class="text-sm text-muted-foreground flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-warning inline-block"></span>Current Title</span>
              <span class="text-foreground font-semibold">${progress.currentTitle || 'Novice'}</span>
            </div>
          </div>
        </div>

        <div class="${cardClass} p-6">
          <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-5 pb-3 border-b border-border">Performance</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center py-3 border-b border-border/50">
              <span class="text-sm text-muted-foreground flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-success inline-block"></span>Levels Completed</span>
              <span class="text-foreground font-semibold">${progress.stats?.levelsCompleted || progress.stats?.dungeonsCompleted || 0}</span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-border/50">
              <span class="text-sm text-muted-foreground flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-warning inline-block"></span>Total Stars</span>
              <span class="text-warning font-semibold">${progress.stats?.totalStarsEarned || 0} ★</span>
            </div>
            <div class="flex justify-between items-center py-3">
              <span class="text-sm text-muted-foreground flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-primary inline-block"></span>Total Play Time</span>
              <span class="text-foreground font-semibold">${playTimeText}</span>
            </div>
          </div>
        </div>

        <div class="${cardClass} p-6 col-span-full">
          <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-5 pb-3 border-b border-border">Unlocked Abilities</h2>
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-3">Nodes</h3>
              <div class="flex flex-wrap gap-2">
                ${(progress.unlockedNodes || []).map((n: string) => `<span class="px-3 py-1.5 rounded-full text-xs font-medium bg-primary/15 text-primary border border-primary/30 capitalize">${n}</span>`).join('')}
              </div>
            </div>
            <div>
              <h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-3">Defenses</h3>
              <div class="flex flex-wrap gap-2">
                ${(progress.unlockedDefenses || []).map((d: string) => `<span class="px-3 py-1.5 rounded-full text-xs font-medium bg-success/15 text-success border border-success/30 capitalize">${d.replace('_', ' ')}</span>`).join('')}
              </div>
            </div>
          </div>
        </div>

        <div class="${cardClass} p-6 col-span-full">
          <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-5 pb-3 border-b border-border">Quick Actions</h2>
          <div class="grid md:grid-cols-2 gap-4">
            <a href="/acts" class="${cardClass} p-6 flex flex-col items-center text-center no-underline hover:bg-accent hover:border-primary/30 hover:shadow-lg transition-all duration-200">
              <svg class="w-10 h-10 mb-3 text-primary" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>
              <span class="text-foreground font-semibold mb-1">Acts</span>
              <span class="text-xs text-muted-foreground">Learn Rails through 35 levels</span>
            </a>
            <a href="/sandbox" class="${cardClass} p-6 flex flex-col items-center text-center no-underline hover:bg-accent hover:border-primary/30 hover:shadow-lg transition-all duration-200">
              <svg class="w-10 h-10 mb-3 text-primary" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              <span class="text-foreground font-semibold mb-1">Sandbox</span>
              <span class="text-xs text-muted-foreground">Practice building pipelines</span>
            </a>
          </div>
        </div>
      `;
    } catch (err) {
      console.error('Dashboard load error:', err);
      const errorMessage = err instanceof Error ? err.message : 'Unknown error';
      const isAuthError = errorMessage.includes('Unauthorized') || errorMessage.includes('Invalid token');

      container.innerHTML = `
        <div class="${cardClass} col-span-full p-12 text-center">
          <p class="text-muted-foreground mb-4">${isAuthError ? 'Please log in to view your dashboard.' : `Error: ${escapeHtml(errorMessage)}`}</p>
          ${isAuthError
            ? `<a href="/login" class="${primaryBtnClass}">Login</a>`
            : `<button class="${secondaryBtnClass}" onclick="window.location.reload()">Retry</button>`
          }
        </div>
      `;
    }
  }

  loadDashboard();
</script>
