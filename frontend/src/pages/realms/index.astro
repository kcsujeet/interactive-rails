---
import GameLayout from '../../layouts/GameLayout.astro';
import RealmMap from '../../components/game/RealmMap';
---

<GameLayout title="Realms">
  <div class="realms-page container">
    <RealmMap client:load />
  </div>
</GameLayout>

<style>
  .realms-page {
    max-width: 1000px;
    margin: 0 auto;
  }

  :global(.realm-map) {
    padding: 24px 0;
  }

  :global(.realm-header) {
    text-align: center;
    margin-bottom: 32px;
  }

  :global(.realm-header h1) {
    margin-bottom: 12px;
  }

  :global(.realm-header p) {
    color: var(--color-text-dim);
  }

  :global(.realm-card) {
    display: flex;
    gap: 16px;
    padding: 20px;
    background: var(--color-bg-light);
    border: 3px solid var(--color-text-dim);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.2s;
    position: relative;
  }

  :global(.realm-card:hover:not(.locked)) {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  :global(.realm-card.locked) {
    opacity: 0.6;
    cursor: not-allowed;
  }

  :global(.realm-icon) {
    font-size: 2.5rem;
    flex-shrink: 0;
  }

  :global(.realm-info) {
    flex: 1;
  }

  :global(.realm-name) {
    font-size: 0.8rem;
    margin-bottom: 8px;
    color: var(--color-accent);
  }

  :global(.realm-desc) {
    font-size: 0.85rem;
    color: var(--color-text-dim);
    margin-bottom: 12px;
  }

  :global(.realm-progress) {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  :global(.progress-bar) {
    flex: 1;
    height: 12px;
    background: var(--color-bg-dark);
    border: 2px solid var(--color-text-dim);
    overflow: hidden;
  }

  :global(.progress-fill) {
    height: 100%;
    background: var(--color-accent);
    transition: width 0.3s;
  }

  :global(.progress-text) {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    white-space: nowrap;
  }

  :global(.realm-complete) {
    position: absolute;
    top: 8px;
    right: 8px;
    background: var(--color-accent);
    color: black;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
  }

  :global(.loading) {
    text-align: center;
    padding: 48px;
  }

  :global(.loading-text) {
    font-family: var(--font-pixel);
    font-size: 0.8rem;
    color: var(--color-text-dim);
    animation: pulse 1.5s infinite;
  }

  :global(.error) {
    text-align: center;
    padding: 24px;
  }
</style>
