---
import GameLayout from '../../../layouts/GameLayout.astro';
import BattleScreen from '../../../components/game/BattleScreen';

const { realm, dungeon } = Astro.params;
---

<GameLayout title={`Battle - ${dungeon}`}>
  <div class="battle-page" data-realm-id={realm} data-dungeon-id={dungeon}>
    <div class="battle-header">
      <a href={`/realms/${realm}`} class="back-link">← Retreat</a>
      <div class="dungeon-info">
        <span class="dungeon-badge" id="dungeon-name">Loading...</span>
        <span class="challenge-counter" id="challenge-counter">0/0</span>
      </div>
    </div>

    <div class="battle-container" id="battle-container">
      <div class="loading">
        <span class="loading-text">Entering dungeon...</span>
      </div>
    </div>
  </div>
</GameLayout>

<script>
  import { getChallenges, submitAnswer, getProgress } from '../../../lib/api';
  import { $progress } from '../../../stores/gameStore';
  import { escapeHtml } from '../../../lib/utils';
  import type { Challenge, ChallengeResult } from '../../../../../shared/types';

  const battlePage = document.querySelector('.battle-page');
  const realmId = battlePage?.getAttribute('data-realm-id');
  const dungeonId = battlePage?.getAttribute('data-dungeon-id');

  let challenges: Challenge[] = [];
  let currentIndex = 0;
  let currentChallenge: Challenge | null = null;
  let startTime = 0;
  let result: ChallengeResult | null = null;
  let monsterHp = 100;
  let playerProgress: any = null;

  async function loadBattle() {
    const container = document.getElementById('battle-container');
    const nameEl = document.getElementById('dungeon-name');

    if (!container || !dungeonId) return;

    try {
      // Load challenges and progress
      const [challengeData, progressData] = await Promise.all([
        getChallenges(dungeonId),
        getProgress()
      ]);

      challenges = challengeData.challenges;
      playerProgress = progressData;
      $progress.set(progressData);

      if (nameEl) {
        nameEl.textContent = dungeonId.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
      }

      if (challenges.length > 0) {
        startChallenge(0);
      } else {
        container.innerHTML = '<div class="error pixel-panel"><p>No challenges found in this dungeon.</p></div>';
      }
    } catch (err) {
      const errorMessage = err instanceof Error ? err.message : 'Unknown error';
      const isAuthError = errorMessage.includes('Unauthorized') || errorMessage.includes('Invalid token');

      container.innerHTML = `
        <div class="error pixel-panel">
          <p>${isAuthError ? 'Session expired. Please log in again.' : `Failed to load battle: ${escapeHtml(errorMessage)}`}</p>
          ${isAuthError
            ? '<a href="/login" class="pixel-btn">Login</a>'
            : '<button class="pixel-btn" onclick="window.location.reload()">Retry</button>'
          }
        </div>
      `;
    }
  }

  function startChallenge(index: number) {
    currentIndex = index;
    currentChallenge = challenges[index];
    startTime = Date.now();
    result = null;
    monsterHp = 100;

    updateCounter();
    renderBattle();
  }

  function updateCounter() {
    const counterEl = document.getElementById('challenge-counter');
    if (counterEl) {
      counterEl.textContent = `${currentIndex + 1}/${challenges.length}`;
    }
  }

  function renderBattle() {
    const container = document.getElementById('battle-container');
    if (!container || !currentChallenge) return;

    const isBoss = currentChallenge.monster.name.toLowerCase().includes('boss');

    container.innerHTML = `
      <div class="battle-screen">
        <!-- Player Stats -->
        <div class="player-stats pixel-panel">
          <div class="stat-row">
            <span class="stat-label">HP</span>
            <div class="stat-bar">
              <div class="stat-bar-fill hp" style="width: ${(playerProgress?.currentHp / playerProgress?.maxHp) * 100}%"></div>
              <span class="stat-bar-text">${playerProgress?.currentHp || 100}/${playerProgress?.maxHp || 100}</span>
            </div>
          </div>
          <div class="stat-row">
            <span class="stat-label">LVL ${playerProgress?.level || 1}</span>
            <span class="stat-value">${playerProgress?.xp || 0} XP</span>
          </div>
        </div>

        <!-- Monster -->
        <div class="monster-area">
          <div class="monster ${result && !result.isCorrect ? 'shake' : ''}" id="monster">
            <div class="monster-name">${escapeHtml(currentChallenge.monster.name)}</div>
            <div class="monster-hp-bar">
              <div class="monster-hp-fill" style="width: ${monsterHp}%; background: ${monsterHp > 50 ? '#27ae60' : monsterHp > 25 ? '#f1c40f' : '#e74c3c'}"></div>
              <span class="monster-hp-text">${Math.round(monsterHp)}%</span>
            </div>
            <div class="monster-sprite ${isBoss ? 'boss' : ''}" style="background: ${getMonsterColor(currentChallenge.monster.name)}">
              <span class="monster-emoji">${getMonsterEmoji(currentChallenge.monster.name)}</span>
              ${isBoss ? '<span class="boss-crown">👑</span>' : ''}
            </div>
          </div>
        </div>

        <!-- Challenge -->
        <div class="challenge-area pixel-panel">
          ${result ? renderResult() : renderChallenge()}
        </div>
      </div>
    `;

    // Attach event listeners
    if (!result) {
      attachChallengeListeners();
    } else {
      document.getElementById('next-btn')?.addEventListener('click', handleNext);
    }
  }

  function renderChallenge(): string {
    if (!currentChallenge) return '';

    let optionsHtml = '';

    if (currentChallenge.type === 'multiple_choice' && currentChallenge.options) {
      optionsHtml = `
        <div class="challenge-options">
          ${currentChallenge.options.map(opt => `
            <button class="option-btn" data-answer="${escapeHtml(opt.id)}">
              <span class="option-key">${escapeHtml(opt.id.toUpperCase())}</span>
              <span class="option-text">${escapeHtml(opt.text)}</span>
            </button>
          `).join('')}
        </div>
      `;
    } else if (currentChallenge.type === 'fill_in_blank') {
      optionsHtml = `
        <div class="challenge-input">
          <input type="text" id="answer-input" placeholder="Type your answer..." autofocus />
        </div>
      `;
    } else if (currentChallenge.type === 'code_analysis' && currentChallenge.options) {
      optionsHtml = `
        <div class="challenge-options">
          ${currentChallenge.options.map(opt => `
            <button class="option-btn" data-answer="${escapeHtml(opt.id)}">
              <span class="option-key">${escapeHtml(opt.id.toUpperCase())}</span>
              <span class="option-text">${escapeHtml(opt.text)}</span>
            </button>
          `).join('')}
        </div>
      `;
    }

    return `
      <div class="challenge-question">
        <h3>${escapeHtml(currentChallenge.question)}</h3>
      </div>
      ${currentChallenge.code_snippet ? `
        <div class="challenge-code">
          <pre><code>${escapeHtml(currentChallenge.code_snippet)}</code></pre>
        </div>
      ` : ''}
      ${optionsHtml}
      <div class="challenge-submit">
        <button class="pixel-btn" id="attack-btn" disabled>⚔️ ATTACK!</button>
      </div>
      <div class="challenge-difficulty">
        <span class="difficulty-label">Difficulty:</span>
        <span class="difficulty-stars">${'★'.repeat(currentChallenge.difficulty)}${'☆'.repeat(5 - currentChallenge.difficulty)}</span>
        <span class="xp-reward">+${currentChallenge.xp_reward} XP</span>
      </div>
    `;
  }

  function renderResult(): string {
    if (!result) return '';

    return `
      <div class="result-display">
        <div class="result-header ${result.isCorrect ? 'correct' : 'incorrect'}">
          <h2>${result.isCorrect ? '⚔️ HIT!' : '💥 MISS!'}</h2>
          ${result.isCorrect
            ? `<p class="xp-gained">+${result.xpGained} XP</p>`
            : `<p class="hp-lost">Monster attacked! -${playerProgress?.currentHp - result.currentHp} HP</p>`
          }
        </div>
        <div class="explanation">
          <h3>Correct Answer: ${escapeHtml(result.correctAnswer)}</h3>
          <p>${escapeHtml(result.explanation)}</p>
        </div>
        ${result.leveledUp ? `
          <div class="level-up">
            🎉 LEVEL UP! You are now level ${result.newLevel}!
          </div>
        ` : ''}
        <button class="pixel-btn" id="next-btn">
          ${currentIndex < challenges.length - 1 ? 'Next Challenge →' : '🏆 Complete Dungeon'}
        </button>
      </div>
    `;
  }

  function attachChallengeListeners() {
    let selectedAnswer: string | null = null;

    // Multiple choice buttons
    document.querySelectorAll('.option-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.option-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        selectedAnswer = btn.getAttribute('data-answer');
        const attackBtn = document.getElementById('attack-btn') as HTMLButtonElement;
        if (attackBtn) attackBtn.disabled = false;
      });
    });

    // Fill in blank input
    const input = document.getElementById('answer-input') as HTMLInputElement;
    if (input) {
      input.addEventListener('input', () => {
        selectedAnswer = input.value;
        const attackBtn = document.getElementById('attack-btn') as HTMLButtonElement;
        if (attackBtn) attackBtn.disabled = !input.value.trim();
      });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && selectedAnswer) {
          handleSubmit(selectedAnswer);
        }
      });
    }

    // Attack button
    document.getElementById('attack-btn')?.addEventListener('click', () => {
      if (selectedAnswer) {
        handleSubmit(selectedAnswer);
      }
    });
  }

  async function handleSubmit(answer: string) {
    if (!currentChallenge) return;

    const attackBtn = document.getElementById('attack-btn') as HTMLButtonElement;
    if (attackBtn) {
      attackBtn.disabled = true;
      attackBtn.textContent = 'Attacking...';
    }

    const timeTaken = Date.now() - startTime;

    try {
      result = await submitAnswer(currentChallenge.id, answer, timeTaken);

      // Update player progress
      playerProgress = {
        ...playerProgress,
        xp: playerProgress.xp + result.xpGained,
        level: result.newLevel,
        currentHp: result.currentHp,
      };
      $progress.set(playerProgress);

      // Update monster HP
      if (result.isCorrect) {
        const damagePercent = Math.min(result.damage / currentChallenge.monster.hp * 100, 100);
        monsterHp = Math.max(0, monsterHp - damagePercent);

        // Shake animation
        const monsterEl = document.getElementById('monster');
        if (monsterEl) {
          monsterEl.classList.add('shake');
          setTimeout(() => monsterEl.classList.remove('shake'), 300);
        }
      }

      renderBattle();
    } catch (err) {
      console.error('Failed to submit answer:', err);
      if (attackBtn) {
        attackBtn.disabled = false;
        attackBtn.textContent = '⚔️ ATTACK!';
      }
    }
  }

  function handleNext() {
    if (currentIndex < challenges.length - 1) {
      startChallenge(currentIndex + 1);
    } else {
      // Dungeon complete!
      window.location.href = `/realms/${realmId}`;
    }
  }

  function getMonsterEmoji(name: string): string {
    const lowerName = name.toLowerCase();
    if (lowerName.includes('boss')) return '👹';
    if (lowerName.includes('bug')) return '🐛';
    if (lowerName.includes('ghost') || lowerName.includes('phantom')) return '👻';
    if (lowerName.includes('dragon')) return '🐉';
    if (lowerName.includes('controller')) return '🎮';
    if (lowerName.includes('model')) return '📦';
    if (lowerName.includes('route')) return '🗺️';
    if (lowerName.includes('query')) return '🔍';
    if (lowerName.includes('validation')) return '⚠️';
    return '👾';
  }

  function getMonsterColor(name: string): string {
    const lowerName = name.toLowerCase();
    if (lowerName.includes('boss')) return 'linear-gradient(135deg, #9b59b6, #8e44ad)';
    if (lowerName.includes('dragon')) return 'linear-gradient(135deg, #e74c3c, #c0392b)';
    if (lowerName.includes('ghost')) return 'linear-gradient(135deg, #95a5a6, #7f8c8d)';
    if (lowerName.includes('bug')) return 'linear-gradient(135deg, #27ae60, #1e8449)';
    return 'linear-gradient(135deg, #34495e, #2c3e50)';
  }

  loadBattle();
</script>

<style>
  .battle-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px;
  }

  .battle-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .back-link {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-text-dim);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .dungeon-info {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .dungeon-badge {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    background: var(--color-secondary);
    padding: 8px 16px;
    text-transform: capitalize;
  }

  .challenge-counter {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-accent);
  }

  :global(.battle-screen) {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  :global(.player-stats) {
    padding: 16px;
  }

  :global(.stat-row) {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  :global(.stat-row:last-child) {
    margin-bottom: 0;
  }

  :global(.stat-label) {
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    min-width: 60px;
    color: var(--color-text-dim);
  }

  :global(.stat-value) {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-accent);
  }

  :global(.monster-area) {
    display: flex;
    justify-content: center;
    padding: 24px;
  }

  :global(.monster) {
    text-align: center;
  }

  :global(.monster.shake) {
    animation: shake 0.3s ease-in-out;
  }

  :global(.monster-name) {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--color-primary);
    margin-bottom: 8px;
  }

  :global(.monster-hp-bar) {
    width: 200px;
    height: 16px;
    background: var(--color-bg-dark);
    border: 2px solid var(--color-text);
    margin: 0 auto 16px;
    position: relative;
  }

  :global(.monster-hp-fill) {
    height: 100%;
    transition: width 0.3s;
  }

  :global(.monster-hp-text) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: white;
    text-shadow: 1px 1px 0 black;
  }

  :global(.monster-sprite) {
    width: 120px;
    height: 120px;
    margin: 0 auto;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    box-shadow: 0 4px 0 rgba(0,0,0,0.3);
  }

  :global(.monster-sprite.boss) {
    width: 150px;
    height: 150px;
    animation: boss-pulse 2s ease-in-out infinite;
  }

  :global(.monster-emoji) {
    font-size: 64px;
    filter: drop-shadow(2px 2px 0 rgba(0,0,0,0.5));
  }

  :global(.boss-crown) {
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 32px;
  }

  :global(.challenge-area) {
    padding: 24px;
  }

  :global(.challenge-question h3) {
    font-size: 1rem;
    margin-bottom: 16px;
    line-height: 1.6;
  }

  :global(.challenge-code) {
    background: var(--color-bg-dark);
    border: 2px solid var(--color-secondary);
    padding: 16px;
    margin-bottom: 20px;
    overflow-x: auto;
  }

  :global(.challenge-code pre) {
    margin: 0;
    font-size: 0.9rem;
  }

  :global(.challenge-options) {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }

  :global(.option-btn) {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    background: var(--color-bg);
    border: 2px solid var(--color-text-dim);
    color: var(--color-text);
    cursor: pointer;
    transition: all 0.2s;
    text-align: left;
  }

  :global(.option-btn:hover) {
    border-color: var(--color-primary);
  }

  :global(.option-btn.selected) {
    border-color: var(--color-accent);
    background: rgba(22, 199, 154, 0.1);
  }

  :global(.option-key) {
    font-family: var(--font-pixel);
    font-size: 0.8rem;
    background: var(--color-secondary);
    padding: 4px 12px;
    min-width: 40px;
    text-align: center;
  }

  :global(.option-text) {
    flex: 1;
  }

  :global(.challenge-input) {
    margin-bottom: 20px;
  }

  :global(.challenge-input input) {
    font-size: 1rem;
    padding: 16px;
  }

  :global(.challenge-submit) {
    text-align: center;
    margin-bottom: 16px;
  }

  :global(.challenge-difficulty) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-family: var(--font-pixel);
    font-size: 0.5rem;
    color: var(--color-text-dim);
  }

  :global(.difficulty-stars) {
    color: var(--color-gold);
  }

  :global(.xp-reward) {
    color: var(--color-accent);
  }

  :global(.result-display) {
    text-align: center;
  }

  :global(.result-header) {
    padding: 24px;
    margin-bottom: 20px;
  }

  :global(.result-header.correct) {
    background: rgba(22, 199, 154, 0.1);
    border: 2px solid var(--color-accent);
  }

  :global(.result-header.incorrect) {
    background: rgba(233, 69, 96, 0.1);
    border: 2px solid var(--color-primary);
  }

  :global(.result-header h2) {
    margin-bottom: 8px;
  }

  :global(.xp-gained) {
    font-family: var(--font-pixel);
    font-size: 1rem;
    color: var(--color-accent);
  }

  :global(.hp-lost) {
    font-family: var(--font-pixel);
    font-size: 0.8rem;
    color: var(--color-primary);
  }

  :global(.explanation) {
    background: var(--color-bg-dark);
    padding: 20px;
    margin-bottom: 20px;
    text-align: left;
  }

  :global(.explanation h3) {
    color: var(--color-accent);
    margin-bottom: 8px;
    font-size: 0.8rem;
  }

  :global(.explanation p) {
    color: var(--color-text-dim);
    line-height: 1.6;
  }

  :global(.level-up) {
    font-family: var(--font-pixel);
    font-size: 0.8rem;
    color: var(--color-gold);
    padding: 16px;
    background: rgba(255, 215, 0, 0.1);
    border: 2px solid var(--color-gold);
    margin-bottom: 20px;
    animation: pulse 1s infinite;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-10px); }
    75% { transform: translateX(10px); }
  }

  @keyframes boss-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  .loading {
    text-align: center;
    padding: 48px;
  }

  .loading-text {
    font-family: var(--font-pixel);
    font-size: 0.8rem;
    color: var(--color-text-dim);
    animation: pulse 1.5s infinite;
  }

  :global(.error) {
    text-align: center;
    padding: 32px;
  }
</style>
