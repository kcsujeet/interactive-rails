---
// Header component - client-side interactivity handled by React islands
---

<header class="header">
  <div class="container header-content">
    <a href="/" class="logo">
      <span class="logo-icon">⚔️</span>
      <span class="logo-text">RailsExpert</span>
    </a>

    <nav class="nav" id="main-nav">
      <a href="/realms" class="nav-link">Realms</a>
      <a href="/dashboard" class="nav-link">Dashboard</a>
    </nav>

    <div class="header-right" id="header-auth">
      <!-- Populated by client-side JS -->
      <a href="/login" class="pixel-btn secondary">Login</a>
    </div>
  </div>
</header>

<script>
  import { $user, initAuth, clearAuth } from '../../stores/authStore';
  import { escapeHtml } from '../../lib/utils';

  // In dev, use relative URL (proxied through Astro dev server for same-origin cookies)
  const API_URL = import.meta.env.DEV ? '' : 'https://api.railsexpert.com';

  // Initialize auth state from localStorage
  initAuth();

  // Update header based on auth state
  function updateHeader() {
    const authContainer = document.getElementById('header-auth');
    const user = $user.get();

    if (user && authContainer) {
      authContainer.innerHTML = `
        <div class="user-info">
          <span class="username">${escapeHtml(user.username)}</span>
          <button id="logout-btn" class="pixel-btn secondary">Logout</button>
        </div>
      `;

      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        // Call logout API to clear HttpOnly cookie
        try {
          await fetch(`${API_URL}/api/auth/logout`, {
            method: 'POST',
            credentials: 'include',
          });
        } catch (e) {
          // Ignore errors, still clear local state
        }
        clearAuth();
        window.location.href = '/';
      });
    }
  }

  updateHeader();

  // Listen for auth changes
  $user.subscribe(updateHeader);
</script>

<style>
  .header {
    background: var(--color-bg-dark);
    border-bottom: 3px solid var(--color-primary);
    padding: 12px 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .logo-icon {
    font-size: 1.5rem;
  }

  .logo-text {
    font-family: var(--font-pixel);
    font-size: 1rem;
    color: var(--color-primary);
    text-transform: uppercase;
  }

  .nav {
    display: flex;
    gap: 24px;
  }

  .nav-link {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-text);
    text-decoration: none;
    text-transform: uppercase;
    padding: 8px 12px;
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .username {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }

    .logo-text {
      font-size: 0.75rem;
    }
  }
</style>
