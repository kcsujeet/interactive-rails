---
// Header component - client-side interactivity handled by script
---

<header class="header">
  <div class="container header-content">
    <a href="/" class="logo">
      <span class="logo-icon">🔧</span>
      <span class="logo-text">RailsExpert</span>
    </a>

    <nav class="nav" id="main-nav">
      <a href="/acts" class="nav-link">Acts</a>
      <a href="/sandbox" class="nav-link">Sandbox</a>
      <a href="/dashboard" class="nav-link">Dashboard</a>
    </nav>

    <div class="header-right" id="header-auth">
      <!-- Populated by client-side JS -->
      <a href="/login" class="btn btn-secondary btn-sm">Login</a>
    </div>
  </div>
</header>

<script>
  import { $user, initAuth, clearAuth } from '../../stores/authStore';
  import { escapeHtml } from '../../lib/utils';

  // In dev, use relative URL (proxied through Astro dev server for same-origin cookies)
  const API_URL = import.meta.env.DEV ? '' : 'https://api.railsexpert.com';

  // Initialize auth state from localStorage
  initAuth();

  // Update header based on auth state
  function updateHeader() {
    const authContainer = document.getElementById('header-auth');
    const user = $user.get();

    if (user && authContainer) {
      authContainer.innerHTML = `
        <div class="user-info">
          <span class="user-level">Lv ${user.level || 1}</span>
          <span class="username">${escapeHtml(user.username)}</span>
          <button id="logout-btn" class="btn btn-ghost btn-sm">Logout</button>
        </div>
      `;

      document.getElementById('logout-btn')?.addEventListener('click', async () => {
        // Call logout API to clear HttpOnly cookie
        try {
          await fetch(`${API_URL}/api/auth/logout`, {
            method: 'POST',
            credentials: 'include',
          });
        } catch (e) {
          // Ignore errors, still clear local state
        }
        clearAuth();
        window.location.href = '/';
      });
    }
  }

  updateHeader();

  // Listen for auth changes
  $user.subscribe(updateHeader);
</script>

<style>
  .header {
    background: var(--color-game-surface);
    border-bottom: 1px solid var(--color-game-border);
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .header-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .logo-icon {
    font-size: 1.25rem;
  }

  .logo-text {
    font-size: 1rem;
    font-weight: 600;
    color: #f3f4f6;
  }

  .nav {
    display: flex;
    gap: 4px;
  }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: #64748b;
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 0.375rem;
    transition: all 150ms;
  }

  .nav-link:hover {
    color: #e2e8f0;
    background: var(--color-game-bg);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  :global(.user-info) {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  :global(.user-level) {
    font-size: 0.75rem;
    font-weight: 600;
    color: #38bdf8;
    padding: 4px 10px;
    background: rgba(14, 165, 233, 0.15);
    border: 1px solid rgba(14, 165, 233, 0.25);
    border-radius: 0.375rem;
  }

  :global(.username) {
    font-size: 0.875rem;
    font-weight: 500;
    color: #e2e8f0;
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }

    .logo-text {
      font-size: 0.9375rem;
    }
  }
</style>
