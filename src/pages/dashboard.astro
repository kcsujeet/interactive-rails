---
import GameLayout from '@/layouts/GameLayout.astro';
import { Button } from '@/components/ui/Button';
import { Card } from '@/components/ui/Card';
import { DashboardCodebaseButton } from '@/features/codebase-viewer/components/DashboardCodebaseButton';
import { getTotalLevelCount } from '@/lib/acts-registry';

const totalLevels = getTotalLevelCount();
---

<GameLayout title="Your Progress">
  <div class="max-w-[1000px] mx-auto p-6">
    <Card className="flex justify-between items-center p-5 mb-8">
      <h1 class="text-2xl font-bold text-foreground">Your Progress</h1>
      <div class="flex items-center gap-3">
        <DashboardCodebaseButton client:load />
        <Button>
          <a href="/acts">Start Learning</a>
        </Button>
      </div>
    </Card>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6" id="dashboard-content" data-total={totalLevels}>
      <div class="bg-card text-card-foreground rounded-xl border py-6 shadow-md p-6">
        <div class="shimmer h-4 w-24 rounded mb-6"></div>
        <div class="space-y-4">
          <div class="shimmer h-3 w-full rounded"></div>
          <div class="shimmer h-3 w-3/4 rounded"></div>
        </div>
      </div>
      <div class="bg-card text-card-foreground rounded-xl border py-6 shadow-md p-6">
        <div class="shimmer h-4 w-24 rounded mb-6"></div>
        <div class="space-y-4">
          <div class="shimmer h-3 w-full rounded"></div>
          <div class="shimmer h-3 w-3/4 rounded"></div>
        </div>
      </div>
      <div class="bg-card text-card-foreground rounded-xl border py-6 shadow-md p-6">
        <div class="shimmer h-4 w-24 rounded mb-6"></div>
        <div class="space-y-4">
          <div class="shimmer h-3 w-full rounded"></div>
          <div class="shimmer h-3 w-3/4 rounded"></div>
        </div>
      </div>
    </div>
  </div>
</GameLayout>

<script>
  import { getProgress } from "@/lib/progress";
  import { escapeHtml } from "@/lib/utils";

  const cardClass = "bg-card text-card-foreground flex flex-col gap-6 rounded-xl border py-6 shadow-md";
  const primaryBtnClass = "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-lg text-sm font-medium transition-colors bg-primary text-primary-foreground shadow hover:bg-primary/90 h-9 px-4 py-2";

  async function loadDashboard() {
    const container = document.getElementById('dashboard-content');
    if (!container) return;

    const totalLevels = Number(container.dataset.total) || 0;
    const progress = await getProgress();

    const completed = progress.completedLevels.length;
    const entries = Object.values(progress.levelProgress);
    const totalStars = entries.reduce((sum, e) => sum + (e.stars || 0), 0);
    const maxStars = completed * 3;
    const percent = totalLevels > 0 ? Math.round((completed / totalLevels) * 100) : 0;
    const dbChoice = progress.stackChoices?.database;
    const dbLabel = dbChoice
      ? dbChoice === 'postgres' ? 'PostgreSQL' : 'SQLite'
      : 'Not chosen yet';

    const statRow = (dot: string, label: string, value: string) => `
      <div class="flex justify-between items-center py-3 border-b border-border/50 last:border-0">
        <span class="text-sm text-muted-foreground flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full ${dot} inline-block"></span>${label}</span>
        <span class="text-foreground font-semibold">${value}</span>
      </div>`;

    container.innerHTML = `
      <div class="${cardClass} p-6">
        <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-5 pb-3 border-b border-border">Levels</h2>
        <div>
          ${statRow('bg-success', 'Completed', `${completed} / ${totalLevels}`)}
          <div class="pt-4">
            <div class="h-2.5 bg-muted rounded-full overflow-hidden">
              <div class="h-full bg-primary rounded-full transition-all duration-700 ease-out" style="width: ${percent}%"></div>
            </div>
            <div class="text-xs text-muted-foreground mt-2 text-right">${percent}% of the curriculum</div>
          </div>
        </div>
      </div>

      <div class="${cardClass} p-6">
        <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-5 pb-3 border-b border-border">Stars</h2>
        <div>
          ${statRow('bg-warning', 'Earned', `${totalStars} / ${maxStars} &#9733;`)}
          ${statRow('bg-primary', 'Per level', `up to 3`)}
        </div>
      </div>

      <div class="${cardClass} p-6">
        <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-5 pb-3 border-b border-border">Your Stack</h2>
        <div>
          ${statRow('bg-primary', 'Database', escapeHtml(dbLabel))}
        </div>
      </div>

      <div class="${cardClass} p-6 col-span-full">
        <h2 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-5 pb-3 border-b border-border">Keep Going</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <a href="/acts" class="${cardClass} p-6 flex flex-col items-center text-center no-underline hover:bg-accent hover:border-primary/30 hover:shadow-lg transition-all duration-200">
            <svg class="w-10 h-10 mb-3 text-primary" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>
            <span class="text-foreground font-semibold mb-1">Acts</span>
            <span class="text-xs text-muted-foreground">Learn Rails through ${totalLevels} levels</span>
          </a>
          <a href="/sandbox" class="${cardClass} p-6 flex flex-col items-center text-center no-underline hover:bg-accent hover:border-primary/30 hover:shadow-lg transition-all duration-200">
            <svg class="w-10 h-10 mb-3 text-primary" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            <span class="text-foreground font-semibold mb-1">Sandbox</span>
            <span class="text-xs text-muted-foreground">Experiment with request flows</span>
          </a>
        </div>
      </div>

      ${completed === 0 ? `
      <div class="${cardClass} col-span-full p-8 text-center">
        <p class="text-muted-foreground mb-4">You have not completed any levels yet. Your progress saves automatically in this browser.</p>
        <a href="/acts" class="${primaryBtnClass}">Start with Level 1</a>
      </div>` : ''}
    `;
  }

  loadDashboard();
</script>
