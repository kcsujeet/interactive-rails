                  <Badge className="font-mono" color="warning" variant="soft" size="xs">Solid Cable</Badge>
                </div>
              </Card>
            </div>

            <div class="relative">
              <div class="flex justify-center mb-4">
                <div class="w-16 h-16 rounded-full bg-red-500/15 border-2 border-red-500/40 flex items-center justify-center relative z-10 shadow-[0_0_0_4px_var(--background)]">
