---
import GameLayout from '@/layouts/GameLayout.astro';
import {
	getActLevelStaticPaths,
	getLevel,
	getActForLevel,
	getNextLevel,
} from '@/lib/acts-registry';
import { Button } from '@/components/ui/Button';
import { CodeBlock } from '@/components/ui/CodeBlock';
import { LevelBreadcrumb } from '@/components/ui/LevelBreadcrumb';
import { MarkdownContent } from '@/components/ui/MarkdownContent';
import {
	Star,
	CheckCircle,
	ArrowRight,
	AlertTriangle,
	BookOpen,
	TerminalSquare,
} from 'lucide-react';

export function getStaticPaths() {
	return getActLevelStaticPaths();
}

const { levelId } = Astro.params;

const level = getLevel(levelId || '');
const act = getActForLevel(levelId || '');
const nextLevel = getNextLevel(levelId || '');

// getStaticPaths only emits valid act/level pairs, so level and act
// always resolve here. Fall back defensively for the type-checker.
const { learningContent, isCapstone } =
	level ?? ({} as NonNullable<typeof level>);

// The star count arrives as a `?stars=N` query param at runtime and is
// read client-side (this page is statically prerendered). Default to 3
// for the no-JS render.
const stars = 3;
const scoreMessage = "Perfect! You've mastered this concept.";
---

<GameLayout title="Level Complete">
  <div class="p-6">
    <div class="max-w-2xl mx-auto">
      {/* Breadcrumb */}
      <LevelBreadcrumb
        client:load
        actName={act?.name ?? ''}
        levelNumber={level?.levelNumber ?? 0}
        currentPage="complete"
      />

      {/* Score Section */}
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-success/15 mb-4">
          <CheckCircle className="w-7 h-7 text-success" />
        </div>
        <h1 class="text-2xl font-bold text-foreground mb-1">
          {isCapstone ? 'Capstone Complete!' : 'Level Complete!'}
        </h1>
        <p class="text-muted-foreground text-sm mb-5">{level?.name}</p>

        {/* Stars (count read from ?stars=N client-side) */}
        <div class="inline-flex items-center gap-3 bg-card border border-border rounded-xl px-6 py-4">
          <div class="flex gap-1" id="stars-row">
            {[1, 2, 3].map((i) => (
              <span data-star={i}>
                <Star
                  className={`w-7 h-7 ${i <= stars ? 'text-warning fill-warning' : 'text-muted'}`}
                />
              </span>
            ))}
          </div>
          <div class="h-8 w-px bg-border" />
          <div class="text-left">
            <div class="text-lg font-bold text-foreground"><span id="stars-count">{stars}</span>/3 Stars</div>
            <div class="text-xs text-muted-foreground" id="score-message">{scoreMessage}</div>
          </div>
        </div>
      </div>

      {/* Learning Section */}
      {learningContent && (
        <div class="space-y-8">
          {/* Section Header */}
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
              <BookOpen className="w-5 h-5 text-primary" />
            </div>
            <div>
              <h2 class="text-lg font-semibold text-foreground">What You Learned</h2>
              <p class="text-sm text-muted-foreground">{learningContent.title}</p>
            </div>
          </div>

          {/* Concept Explanation */}
          <div class="bg-card rounded-xl border border-border p-6">
            <MarkdownContent client:load content={learningContent.conceptExplanation} />
          </div>

          {/* Code Example */}
          <div>
            <h3 class="text-sm font-semibold text-foreground mb-3 flex items-center gap-2">
              <CheckCircle className="w-4 h-4 text-success" />
              Here's how it looks in Rails
            </h3>
            <div class="rounded-xl border border-border overflow-hidden">
              <CodeBlock client:load code={learningContent.railsCodeExample} language="ruby" />
            </div>
          </div>

          {/* Homework: do it for real */}
          {learningContent.homework && learningContent.homework.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-foreground mb-3 flex items-center gap-2">
                <TerminalSquare className="w-4 h-4 text-primary" />
                Now do it for real
              </h3>
              <p class="text-sm text-muted-foreground mb-4">
                Open a real terminal in your companion Rails project and work
                through these. The game taught the concept; this is where it
                becomes muscle memory.
              </p>
              <div class="space-y-4">
                {learningContent.homework.map((exercise, index) => (
                  <div class="bg-card rounded-xl border border-border p-5">
                    <div class="flex items-start gap-3 mb-3">
                      <span class="text-primary font-bold text-sm mt-0.5">{index + 1}.</span>
                      <p class="text-sm text-foreground">{exercise.task}</p>
                    </div>
                    {exercise.commands && exercise.commands.length > 0 && (
                      <div class="rounded-lg border border-border overflow-hidden mb-3">
                        <CodeBlock
                          client:load
                          code={exercise.commands.join('\n')}
                          language="bash"
                        />
                      </div>
                    )}
                    <p class="text-xs text-muted-foreground">
                      <span class="font-semibold">Verify:</span> {exercise.verify}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Common Mistakes */}
          {learningContent.commonMistakes.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-foreground mb-3 flex items-center gap-2">
                <AlertTriangle className="w-4 h-4 text-warning" />
                Watch out for these mistakes
              </h3>
              <div class="bg-warning/5 border border-warning/20 rounded-xl p-5">
                <ul class="space-y-3">
                  {learningContent.commonMistakes.map((mistake) => (
                    <li class="flex items-start gap-3 text-sm">
                      <span class="text-warning font-bold mt-0.5">×</span>
                      <span class="text-foreground">{mistake}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )}
        </div>
      )}

      {/* Actions */}
      <div class="mt-10 pt-6 border-t border-border">
        {nextLevel ? (
          <a href={`/acts/${nextLevel.actId}/${nextLevel.id}`}>
            <Button className="w-full">
              Next Step
              <ArrowRight className="w-4 h-4 ml-2" />
            </Button>
          </a>
        ) : (
          <a href="/acts">
            <Button className="w-full">
              Back to All Acts
              <ArrowRight className="w-4 h-4 ml-2" />
            </Button>
          </a>
        )}
      </div>
    </div>
  </div>
</GameLayout>

<script>
  // Read the star count from the URL (?stars=N) and reflect it. The page
  // is statically prerendered with a default of 3, so this runs on load.
  const params = new URLSearchParams(window.location.search);
  const raw = parseInt(params.get('stars') || '3', 10);
  const stars = Number.isNaN(raw) ? 3 : Math.min(3, Math.max(1, raw));

  const row = document.getElementById('stars-row');
  if (row) {
    for (const span of row.querySelectorAll('[data-star]')) {
      const index = Number((span as HTMLElement).dataset.star);
      const svg = span.querySelector('svg');
      if (!svg) continue;
      svg.classList.remove('text-warning', 'fill-warning', 'text-muted');
      if (index <= stars) {
        svg.classList.add('text-warning', 'fill-warning');
      } else {
        svg.classList.add('text-muted');
      }
    }
  }

  const count = document.getElementById('stars-count');
  if (count) count.textContent = String(stars);

  const message = document.getElementById('score-message');
  if (message) {
    message.textContent =
      stars === 3
        ? "Perfect! You've mastered this concept."
        : stars === 2
          ? "Great job! You've got the basics down."
          : 'Good start! Consider revisiting this level later.';
  }
</script>
