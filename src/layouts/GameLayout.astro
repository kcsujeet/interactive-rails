---
import Header from '@/components/ui/Header.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
	title: string;
	fullscreen?: boolean;
}

const { title, fullscreen = false } = Astro.props;
---

<BaseLayout title={title}>
  <div class:list={["game-container", { "game-container--fullscreen": fullscreen }]}>
    {fullscreen ? (
      <Header hideNav compact />
    ) : (
      <Header />
    )}
    <main class:list={["game-main", { "game-main--fullscreen": fullscreen }]}>
      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  .game-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--color-background);
  }

  .game-container--fullscreen {
    height: 100vh;
    overflow: hidden;
  }

  .game-main {
    flex: 1;
    padding: 24px;
  }

  .game-main--fullscreen {
    padding: 0;
    overflow: hidden;
    /* Make this a flex container so the LevelLayout's <Group> child gets
       a definite height to inherit. Without display:flex+flex-direction,
       the child resolves to natural content height and percentage-based
       sizing (h-full / flex-1 / h-[N%]) inside the level breaks silently —
       which is what caused L15's terminal to be pushed off-screen. */
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

</style>
