{
	"name": "interactive-rails",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2024-09-23",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"vars": {
		"ENVIRONMENT": "development"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "interactive-rails-db",
			"database_id": "local"
		}
	],
	"observability": {
		"enabled": true
	}
}
